# AgentRealm Environment Configuration

# Path to the Global AgentBrain Knowledge Base (Single Source of Truth)
# Default is ~/.agentbrain in the user's home directory.
# This folder contains shared skills, system prompts, and lessons learned.
GLOBAL_BRAIN_PATH=~/.agentbrain

# Google Gemini API Key for Cloud RAG mode
# Get one at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_api_key_here
